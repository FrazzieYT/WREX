<Window x:Class="SystemManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:SystemManager.ViewModels"
        xmlns:v="clr-namespace:SystemManager.Views"
        xmlns:local="clr-namespace:SystemManager.Converters"
        Title="WREX - System Manager"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    
    <Window.Resources>
        <SolidColorBrush x:Key="DarkBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SidebarBackground" Color="#252526"/>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
        
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
        
        <!-- Стандартный WPF конвертер для ProgressBar -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExplorerViewModel}">
            <v:ExplorerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskManagerViewModel}">
            <v:TaskManagerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConsoleViewModel}">
            <v:ConsoleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UtilitiesViewModel}">
            <v:UtilitiesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <v:HistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegistryViewModel}">
            <v:RegistryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CleanupViewModel}">
            <v:CleanupView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковое меню -->
            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBackground}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" 
                                Orientation="Vertical" 
                                Margin="20,25,20,30"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Shield" 
                                                     Width="36" Height="36"
                                                     Foreground="{StaticResource AccentColor}"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Text="WREX" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" 
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="github.com/FrazzieYT/WREX" 
                                   FontSize="11" 
                                   Foreground="#569CD6"
                                   Margin="0,4,0,0"
                                   Cursor="Hand"
                                   ToolTip="Открыть репозиторий на GitHub"
                                   MouseLeftButtonDown="GitHubLink_MouseLeftButtonDown"/>
                    </StackPanel>

                    <ListBox Margin="0,10,0,0"
                             SelectedIndex="{Binding SelectedMenuIndex, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="10,5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" 
                                                    Background="Transparent" 
                                                    CornerRadius="6"
                                                    Padding="12,10">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Home" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Главная" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderOpen" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Проводник" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Memory" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Диспетчер памяти" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Console" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Консоль" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Tools" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Утилиты" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="History" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="История" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Broom" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Очистка" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Database" Width="22" Height="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Реестр" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="14"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Контент -->
            <Border Grid.Column="1" Background="{StaticResource DarkBackground}">
                <ContentControl Content="{Binding CurrentView}" Margin="0"/>
            </Border>
        </Grid>

        <!-- Строка состояния -->
        <Border Grid.Row="1" 
                Background="{Binding CurrentStatus, Converter={StaticResource StatusToColorConverter}}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Height="28">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"
                           Margin="0,0,8,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="●"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStatus}" Value="{x:Static vm:OperationStatus.Ready}">
                                    <Setter Property="Text" Value="●"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStatus}" Value="{x:Static vm:OperationStatus.Processing}">
                                    <Setter Property="Text" Value="◉"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStatus}" Value="{x:Static vm:OperationStatus.Completed}">
                                    <Setter Property="Text" Value="✓"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStatus}" Value="{x:Static vm:OperationStatus.Error}">
                                    <Setter Property="Text" Value="✗"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentStatus}" Value="{x:Static vm:OperationStatus.Warning}">
                                    <Setter Property="Text" Value="⚠"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontSize="12"/>
                
                <TextBlock Grid.Column="2"
                           Text="{Binding AdminStatus}"
                           Foreground="White"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="20,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>