<UserControl x:Class="SystemManager.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SystemManager.ViewModels">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
        <StackPanel Margin="30">
            <TextBlock Text="Добро пожаловать в WREX"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,5"/>
            <TextBlock Text="Централизованное управление системными компонентами Windows"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0,0,0,30"/>

            <!-- Информация о системе -->
            <TextBlock Text="Информация о системе" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,25"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,5">
                        <TextBlock Text="Имя компьютера" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding ComputerName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,5">
                        <TextBlock Text="Пользователь" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding UserName}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,5">
                        <TextBlock Text="Версия ОС" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding OsVersion}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,5">
                        <TextBlock Text=".NET Runtime" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding DotNetVersion}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,5">
                        <TextBlock Text="Процессоров" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding ProcessorCount}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,5">
                        <TextBlock Text="Архитектура" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding Is64Bit, StringFormat='64-bit: {0}'}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5">
                        <TextBlock Text="Системная папка" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Text="{Binding SystemDir}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Диски -->
            <TextBlock Text="Дисковое пространство" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>
            <ItemsControl ItemsSource="{Binding Drives}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DriveInfoItem}">
                        <Border Background="{StaticResource CardBackground}"
                                CornerRadius="8" Padding="15" Margin="0,0,0,10"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Harddisk" Width="32" Height="32"
                                                         VerticalAlignment="Center"
                                                         Foreground="{StaticResource AccentColor}"
                                                         Margin="0,0,15,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}">
                                        <Run Text="{Binding Name, Mode=OneTime}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding VolumeLabel, Mode=OneTime}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondary}">
                                        <Run Text="Свободно: "/>
                                        <Run Text="{Binding AvailableFreeSpace, StringFormat={}{0:N0} байт}"/>
                                        <Run Text=" из "/>
                                        <Run Text="{Binding TotalSize, StringFormat={}{0:N0} байт}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>