<UserControl x:Class="SystemManager.Views.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SystemManager.Converters"
             Background="#1E1E1E">
    
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
        
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D5689"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#0E7A3A"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#C50F1F"/>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#8B5CF6"/>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с кнопками действий -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔧 Редактор реестра" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#CCCCCC" 
                           VerticalAlignment="Center" 
                           Margin="0,0,20,0"/>
                
                <Button Content="➕ Создать ключ" 
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding CreateKeyCommand}"/>
                
                <Button Content="🗑️ Удалить ключ" 
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteKeyCommand}"/>
                
                <Button Content="✏️ Переименовать ключ" 
                        Style="{StaticResource WarningButton}"
                        Command="{Binding RenameKeyCommand}"/>
                
                <Separator Margin="10,0"/>
                
                <Button Content="⭐ В избранное" 
                        Style="{StaticResource ModernButton}"
                        Command="{Binding AddFavoriteCommand}"/>
            </StackPanel>
        </Border>

        <!-- Основной контент с вкладками -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            
            <!-- Вкладка 1: Реестр -->
            <TabItem Header="📁 Реестр" Background="#2D2D30" Foreground="#CCCCCC">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Дерево ключей -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Ключи реестра" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#CCCCCC" 
                                   Margin="10,10,10,5"/>

                        <TreeView Grid.Row="1" 
                                  ItemsSource="{Binding RootKeys}" 
                                  SelectedItemChanged="TreeView_SelectedItemChanged"
                                  ContextMenu="{StaticResource RegistryKeyContextMenu}"
                                  Margin="5">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁 " Foreground="#FFD700"/>
                                        <TextBlock Text="{Binding Name}" Foreground="#CCCCCC"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                        </TreeView>
                    </Grid>

                    <!-- Разделитель -->
                    <GridSplitter Grid.Column="1" 
                                  Width="5" 
                                  HorizontalAlignment="Stretch" 
                                  Background="#3F3F46"/>

                    <!-- Значения -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="Значения" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="#CCCCCC" 
                                   Margin="10,10,10,5"/>

                        <!-- Кнопки действий для значений -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                            <Button Content="➕ Создать значение" 
                                    Style="{StaticResource SuccessButton}"
                                    Command="{Binding CreateValueCommand}"/>
                            <Button Content="🗑️ Удалить" 
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding DeleteValueCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ValuesList}"/>
                            <Button Content="✏️ Переименовать" 
                                    Style="{StaticResource WarningButton}"
                                    Command="{Binding RenameValueCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ValuesList}"/>
                            <Button Content="💾 Изменить" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding EditValueCommand}"
                                    CommandParameter="{Binding SelectedItem, ElementName=ValuesList}"/>
                        </StackPanel>

                        <ListView Grid.Row="2" 
                                  x:Name="ValuesList"
                                  ItemsSource="{Binding Values}" 
                                  ContextMenu="{StaticResource RegistryValueContextMenu}"
                                  Margin="5"
                                  MouseDoubleClick="ValuesList_MouseDoubleClick">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Имя" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Тип" Width="100" DisplayMemberBinding="{Binding Kind}"/>
                                    <GridViewColumn Header="Значение" Width="300" DisplayMemberBinding="{Binding ValueDisplay}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Избранное -->
            <TabItem Header="⭐ Избранное" Background="#2D2D30" Foreground="#CCCCCC">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Избранные ключи" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#CCCCCC" 
                               Margin="10,10,10,5"/>

                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding Favorites}"
                              Margin="5"
                              MouseDoubleClick="FavoritesList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Имя" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Путь" Width="500" DisplayMemberBinding="{Binding Path}"/>
                                <GridViewColumn Header="Куст" Width="150" DisplayMemberBinding="{Binding HiveDisplay}"/>
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="🗑️ Удалить из избранного" 
                                          Command="{Binding RemoveFavoriteCommand}"
                                          CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Вкладка 3: Поиск -->
            <TabItem Header="🔍 Поиск" Background="#2D2D30" Foreground="#CCCCCC">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель поиска -->
                    <Border Grid.Row="0" Background="#2D2D30" Padding="10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" 
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,10,0"/>

                                <Button Grid.Column="1" 
                                        Content="🔍 Искать" 
                                        Style="{StaticResource ModernButton}"
                                        Command="{Binding SearchCommand}"
                                        IsEnabled="{Binding IsSearching, Converter={StaticResource InverseBoolConverter}}"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <CheckBox Content="Искать в именах ключей" IsChecked="{Binding SearchKeys}"/>
                                <CheckBox Content="Искать в именах значений" IsChecked="{Binding SearchValues}"/>
                                <CheckBox Content="Искать в данных значений" IsChecked="{Binding SearchValueData}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1" 
                               Text="Результаты поиска" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#CCCCCC" 
                               Margin="10,10,10,5"/>

                    <ListView Grid.Row="2" 
                              ItemsSource="{Binding SearchResults}" 
                              Margin="5"
                              MouseDoubleClick="SearchResults_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Тип" Width="80" DisplayMemberBinding="{Binding Type}"/>
                                <GridViewColumn Header="Имя" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Путь" Width="400" DisplayMemberBinding="{Binding Path}"/>
                                <GridViewColumn Header="Значение" Width="300" DisplayMemberBinding="{Binding Value}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Строка состояния
        <Border Grid.Row="2" Background="#007ACC" Padding="10">
            <TextBlock Text="{Binding StatusMessage, FallbackValue='Готово'}" 
                       Foreground="White" 
                       FontSize="12"/>
        </Border> -->
    </Grid>
</UserControl>