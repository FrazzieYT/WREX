<UserControl x:Class="SystemManager.Views.TaskManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemManager.ViewModels">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Диспетчер задач" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <!-- Процессы -->
            <TabItem Header="Процессы" Background="#2D2D30" Foreground="#CCCCCC">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                 Padding="10,8" FontSize="14"/>
                        <Button Grid.Column="1" Content="🔄" Command="{Binding RefreshCommand}"
                                Margin="10,0,0,0" Padding="10,8"
                                Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="14"/>
                        <Button Grid.Column="2" Content="▶ Запустить" Command="{Binding RunProcessCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#107C10" Foreground="White"/>
                        <Button Grid.Column="3" Content="⛔ Завершить" Command="{Binding KillCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#D42B2B" Foreground="White"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Processes}"
                              SelectedItem="{Binding SelectedProcess}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                              RowBackground="{StaticResource CardBackground}" AlternatingRowBackground="#333337"
                              BorderBrush="{StaticResource BorderBrush}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" FontSize="13">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="⛔ Завершить" Command="{Binding KillCommand}"/>
                                <MenuItem Header="🔄 Перезапустить" Command="{Binding RestartProcessCommand}" CommandParameter="{Binding SelectedProcess}"/>
                                <Separator/>
                                <MenuItem Header="📂 Открыть расположение" Command="{Binding OpenFileLocationCommand}" CommandParameter="{Binding SelectedProcess}"/>
                                <MenuItem Header="ℹ️ Свойства" Command="{Binding ShowPropertiesCommand}" CommandParameter="{Binding SelectedProcess}"/>
                                <Separator/>
                                <MenuItem Header="📋 Копировать имя" Command="{Binding CopyProcessNameCommand}" CommandParameter="{Binding SelectedProcess}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding StatusIcon}" Width="30"/>
                            <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="100"/>
                            <DataGridTextColumn Header="Память (МБ)" Binding="{Binding MemoryMb}" Width="120"/>
                            <DataGridTextColumn Header="Потоки" Binding="{Binding Threads}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Margin="0,10,0,0" Foreground="{StaticResource TextSecondary}" FontSize="12">
                        <Run Text="Процессов: "/><Run Text="{Binding Processes.Count, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </TabItem>

            <!-- Автозагрузка -->
            <TabItem Header="Автозагрузка" Background="#2D2D30" Foreground="#CCCCCC">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding StartupSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                 Padding="10,8" FontSize="14"/>
                        <Button Grid.Column="1" Content="🔄" Command="{Binding RefreshStartupCommand}"
                                Margin="10,0,0,0" Padding="10,8"
                                Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="14"/>
                        <Button Grid.Column="2" Content="➕ Добавить" Command="{Binding AddStartupEntryCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#107C10" Foreground="White"/>
                    </Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding StartupEntries}"
                              SelectedItem="{Binding SelectedStartupEntry}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                              RowBackground="{StaticResource CardBackground}" AlternatingRowBackground="#333337"
                              BorderBrush="{StaticResource BorderBrush}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" FontSize="13">
                        <DataGrid.ContextMenu>
                            <ContextMenu Background="#2D2D30" Foreground="#CCCCCC">
                                <MenuItem Header="✏️ Изменить" Command="{Binding RenameStartupEntryCommand}"/>
                                <MenuItem Header="🗑️ Удалить" Command="{Binding DeleteStartupEntryCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding SourceIcon}" Width="30"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Команда" Binding="{Binding Command}" Width="350"/>
                            <DataGridTextColumn Header="Источник" Binding="{Binding Source}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Службы -->
            <TabItem Header="Службы" Background="#2D2D30" Foreground="#CCCCCC">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding ServiceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                 Padding="10,8" FontSize="14"/>
                        <Button Grid.Column="1" Content="🔄" Command="{Binding RefreshServicesCommand}"
                                Margin="10,0,0,0" Padding="10,8"
                                Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="14"/>
                        <Button Grid.Column="2" Content="▶" Command="{Binding StartServiceCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#107C10" Foreground="White"/>
                        <Button Grid.Column="3" Content="⏹" Command="{Binding StopServiceCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#D42B2B" Foreground="White"/>
                        <Button Grid.Column="4" Content="🔄" Command="{Binding RestartServiceCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#FFB900" Foreground="White"/>
                        <Button Grid.Column="5" Content="➕ Добавить" Command="{Binding AddServiceCommand}"
                                Margin="5,0,0,0" Padding="10,8" Background="#107C10" Foreground="White"/>
                    </Grid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Тип запуска:" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="🔧 Авто" Command="{Binding SetServiceAutoCommand}"
                                Padding="10,4" Margin="0,0,5,0"
                                Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="11"/>
                        <Button Content="✋ Вручную" Command="{Binding SetServiceManualCommand}"
                                Padding="10,4" Margin="0,0,5,0"
                                Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="11"/>
                        <Button Content="🚫 Отключена" Command="{Binding SetServiceDisabledCommand}"
                                Padding="10,4"
                                Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="11"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredServices}"
                              SelectedItem="{Binding SelectedService}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                              RowBackground="{StaticResource CardBackground}" AlternatingRowBackground="#333337"
                              BorderBrush="{StaticResource BorderBrush}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" FontSize="13">
                        <DataGrid.ContextMenu>
                            <ContextMenu Background="#2D2D30" Foreground="#CCCCCC">
                                <MenuItem Header="✏️ Изменить" Command="{Binding ChangeServiceCommand}" 
                                          CommandParameter="{Binding SelectedService}"/>
                                <MenuItem Header="▶ Запустить" Command="{Binding StartServiceCommand}"/>
                                <MenuItem Header="⏹ Остановить" Command="{Binding StopServiceCommand}"/>
                                <MenuItem Header="🔄 Перезапустить" Command="{Binding RestartServiceCommand}"/>
                                <Separator/>
                                <MenuItem Header="🔧 Авто" Command="{Binding SetServiceAutoCommand}"/>
                                <MenuItem Header="✋ Вручную" Command="{Binding SetServiceManualCommand}"/>
                                <MenuItem Header="🚫 Отключена" Command="{Binding SetServiceDisabledCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding StatusIcon}" Width="30"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Отображаемое" Binding="{Binding DisplayName}" Width="250"/>
                            <DataGridTextColumn Header="Состояние" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Запуск" Binding="{Binding StartMode}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" Margin="0,10,0,0" Foreground="{StaticResource TextSecondary}" FontSize="12">
                        <Run Text="Служб: "/><Run Text="{Binding FilteredServices.Count, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
