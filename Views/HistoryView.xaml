<UserControl x:Class="SystemManager.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemManager.ViewModels"
             xmlns:converters="clr-namespace:SystemManager.Converters"
             Background="#1E1E1E">
    <UserControl.Resources>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="📊 История операций"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="🗑️ Очистить" Command="{Binding ClearCommand}"
                            Padding="15,8" Background="#C50F1F" Foreground="White" BorderThickness="0"/>
                    <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}"
                            Padding="15,8" Margin="10,0,0,0" Background="#0E639C" Foreground="White" BorderThickness="0"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0" Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#3F3F46" Padding="8,6"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding CategoryFilter}" Width="150"
                              Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#3F3F46"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <ListView Grid.Row="1" ItemsSource="{Binding FilteredEntries}" Margin="5"
                  Background="#252526" Foreground="#CCCCCC" BorderBrush="#3F3F46">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Время" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}" Foreground="#CCCCCC"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="Категория" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Category, Converter={StaticResource CategoryColorConverter}}"
                                        CornerRadius="3" Padding="5,2">
                                    <TextBlock Text="{Binding Category}" Foreground="White" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="Действие" Width="250">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Action}" Foreground="#CCCCCC"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="Детали" Width="500">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Details}" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
            
            <ListView.ContextMenu>
                <ContextMenu Background="#2D2D30" Foreground="#CCCCCC">
                    <MenuItem Header="📋 Копировать" Click="CopyHistoryEntry_Click"/>
                    <Separator/>
                    <MenuItem Header="🗑️ Удалить запись" Command="{Binding DeleteCommand}"
                              CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</UserControl>
