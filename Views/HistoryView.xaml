<UserControl x:Class="SystemManager.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemManager.ViewModels"
             xmlns:converters="clr-namespace:SystemManager.Converters"
             Background="#1E1E1E">
    <UserControl.Resources>
        <converters:CategoryColorConverter x:Key="CategoryColorConverter"/>
        
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#C50F1F"/>
        </Style>
        
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Панель управления -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="📊 История операций"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    
                    <Button Content="🗑️ Очистить историю"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ClearCommand}"/>
                    
                    <Button Content="🔄 Обновить"
                            Style="{StaticResource ModernButton}"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0"
                             Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0"/>
                    
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding CategoryFilter}"
                              Width="150"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <!-- Список истории -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding FilteredEntries}"
                  Margin="5">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Время" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:dd.MM.yyyy HH:mm:ss}}"
                                           Foreground="#CCCCCC"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="Категория" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Category, Converter={StaticResource CategoryColorConverter}}"
                                        CornerRadius="3"
                                        Padding="5,2">
                                    <TextBlock Text="{Binding Category}"
                                               Foreground="White"
                                               FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <GridViewColumn Header="Действие" Width="250" DisplayMemberBinding="{Binding Action}"/>
                    <GridViewColumn Header="Детали" Width="500" DisplayMemberBinding="{Binding Details}"/>
                </GridView>
            </ListView.View>
            
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="📋 Копировать" Click="CopyHistoryEntry_Click"/>
                    <Separator/>
                    <MenuItem Header="🗑️ Удалить запись"
                              Command="{Binding DeleteCommand}"
                              CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </Grid>
</UserControl>