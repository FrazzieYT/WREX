<UserControl x:Class="SystemManager.Views.ExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ContextMenus.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <DockPanel Grid.Row="0" Margin="5">
            <Button Content="🏠" Command="{Binding NavigateHomeCommand}" 
                    Padding="8,5" Margin="0,0,5,0" FontSize="14" ToolTip="Домой"
                    Background="#2D2D30" Foreground="White" BorderBrush="#3E3E42" BorderThickness="1"/>
            <Button Content="🔄" Command="{Binding RefreshCommand}" 
                    Padding="8,5" Margin="0,0,5,0" FontSize="14" ToolTip="Обновить"
                    Background="#2D2D30" Foreground="White" BorderBrush="#3E3E42" BorderThickness="1"/>
            <TextBox Text="{Binding CurrentPath, UpdateSourceTrigger=PropertyChanged}" 
                     VerticalContentAlignment="Center" Margin="0,0,5,0"
                     Background="#3C3C3C" Foreground="White" BorderBrush="#3E3F46" Padding="5,4" FontSize="13">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding NavigateCommand}" 
                               CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </TextBox.InputBindings>
            </TextBox>
        </DockPanel>

        <!-- Строка поиска -->
        <Border Grid.Row="1" Background="#252526" Padding="5" Margin="5,0,5,5" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="White"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Background="#3C3C3C" Foreground="White" BorderBrush="#3F3F46"
                         Padding="5,4" FontSize="13"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusText}" 
                           Foreground="#888888" FontSize="11" 
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- Файлы + предпросмотр -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Файловый список -->
            <ListBox Grid.Column="0" ItemsSource="{Binding FilteredItems}" 
                     SelectedItem="{Binding SelectedItem}"
                     Background="#2D2D30" Foreground="White"
                     MouseDoubleClick="ListBox_MouseDoubleClick"
                     ContextMenu="{StaticResource ExplorerBackgroundContextMenu}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="ContextMenu" Value="{StaticResource ExplorerItemContextMenu}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="5,0" 
                                      VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding FormattedSize}" 
                                      HorizontalAlignment="Right" Margin="5,0" 
                                      Foreground="#888888" VerticalAlignment="Center" FontSize="11"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#3F3F46"/>

            <!-- Предпросмотр -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Просмотр" FontSize="14" FontWeight="SemiBold"
                               Foreground="#CCCCCC" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="{Binding SelectedItem.Icon}"
                               FontSize="32" HorizontalAlignment="Center" Margin="0,5"/>
                    <TextBox Grid.Row="2"
                             Text="{Binding PreviewText, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="Transparent" Foreground="#AAAAAA"
                             FontFamily="Consolas" FontSize="11"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding SelectedItemInfo}" 
                   Foreground="#888888" FontSize="11" Margin="10,3"/>
    </Grid>
</UserControl>
