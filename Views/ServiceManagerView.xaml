<UserControl x:Class="SystemManager.Views.ServiceManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#107C10"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E81123"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFB900"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Менеджер служб" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

        <!-- Поиск и кнопки -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="{StaticResource CardBackground}"
                     Foreground="{StaticResource TextPrimary}"
                     Padding="10,8" FontSize="14"/>

            <Button Grid.Column="1" Content="🔄" Command="{Binding RefreshCommand}"
                    Margin="10,0,0,0" Padding="10,8"
                    Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="14"/>

            <Button Grid.Column="2" Content="▶ Запустить" Command="{Binding StartServiceCommand}"
                    Margin="5,0,0,0" Padding="10,8"
                    Background="{StaticResource SuccessColor}" Foreground="White"/>

            <Button Grid.Column="3" Content="⏹ Остановить" Command="{Binding StopServiceCommand}"
                    Margin="5,0,0,0" Padding="10,8"
                    Background="{StaticResource DangerColor}" Foreground="White"/>

            <Button Grid.Column="4" Content="🔄 Перезапустить" Command="{Binding RestartServiceCommand}"
                    Margin="5,0,0,0" Padding="10,8"
                    Background="{StaticResource WarningColor}" Foreground="White"/>
        </Grid>

        <!-- Таблица служб -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Services}"
                  SelectedItem="{Binding SelectedService}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Background="{StaticResource CardBackground}"
                  Foreground="{StaticResource TextPrimary}"
                  RowBackground="{StaticResource CardBackground}"
                  AlternatingRowBackground="#333337"
                  BorderBrush="{StaticResource BorderBrush}"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="" Binding="{Binding StatusIcon}" Width="30"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Отображаемое имя" Binding="{Binding DisplayName}" Width="300"/>
                <DataGridTextColumn Header="Состояние" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Тип запуска" Binding="{Binding StartMode}" Width="100"/>
                <DataGridTextColumn Header="Учётная запись" Binding="{Binding Account}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Нижняя панель -->
        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                       Foreground="{StaticResource TextSecondary}" FontSize="12"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="🔧 Авто" Command="{Binding SetAutoCommand}"
                        Padding="8,4" Margin="3,0"
                        Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="11"/>
                <Button Content="✋ Вручную" Command="{Binding SetManualCommand}"
                        Padding="8,4" Margin="3,0"
                        Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="11"/>
                <Button Content="🚫 Отключена" Command="{Binding SetDisabledCommand}"
                        Padding="8,4" Margin="3,0"
                        Background="{StaticResource CardBackground}" Foreground="{StaticResource TextPrimary}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" FontSize="11"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
