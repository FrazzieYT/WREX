<UserControl x:Class="SystemManager.Views.UtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemManager.ViewModels"
             Background="#1E1E1E">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3E3E42"/>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
    </UserControl.Resources>

    <TabControl Background="Transparent" BorderThickness="0" Margin="10">

        <!-- Вкладка 1: Утилиты -->
        <TabItem Header="🔧 Утилиты" Background="#2D2D30" Foreground="#CCCCCC">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <TextBlock Text="Системные утилиты" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding Utilities}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:UtilityItem}">
                                <Button Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" Width="180" Height="80" Margin="5"
                                        Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#AAAAAA"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Точки восстановления -->
                    <TextBlock Text="Точки восстановления" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,20,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🔄" Command="{Binding RefreshRestorePointsCommand}" Padding="10,8" Margin="0,0,10,0"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                        <Button Content="➕ Создать" Command="{Binding CreateRestorePointCommand}" Padding="15,8"
                                Background="#107C10" Foreground="White"/>
                    </StackPanel>
                    <ListView ItemsSource="{Binding RestorePoints}" Background="#252526" Foreground="#CCCCCC"
                              BorderBrush="#3E3E42" BorderThickness="1" MaxHeight="120">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="50" DisplayMemberBinding="{Binding SequenceNumber}"/>
                                <GridViewColumn Header="Описание" Width="200" DisplayMemberBinding="{Binding Description}"/>
                                <GridViewColumn Header="Дата" Width="150" DisplayMemberBinding="{Binding FormattedTime}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Экспорт -->
                    <TextBlock Text="Экспорт" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,20,0,10"/>
                    <Button Content="📄 Экспорт системной информации" Command="{Binding ExportSystemInfoCommand}"
                            Padding="15,8" Background="#0078D4" Foreground="White"/>

                    <!-- Реестр -->
                    <TextBlock Text="Экспорт/Импорт реестра" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,20,0,10"/>
                    <WrapPanel Margin="0,0,0,10">
                        <Button Content="💾 HKCU" Command="{Binding ExportHiveCommand}" CommandParameter="HKCU" Padding="15,8" Margin="5"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                        <Button Content="💾 HKLM" Command="{Binding ExportHiveCommand}" CommandParameter="HKLM" Padding="15,8" Margin="5"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                        <Button Content="💾 HKCR" Command="{Binding ExportHiveCommand}" CommandParameter="HKCR" Padding="15,8" Margin="5"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                        <Button Content="💾 HKU" Command="{Binding ExportHiveCommand}" CommandParameter="HKU" Padding="15,8" Margin="5"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                    </WrapPanel>
                    <Button Content="📥 Импорт из .reg файла" Command="{Binding ImportHiveCommand}" Padding="15,8" Background="#FFB900" Foreground="White"/>
                    <TextBlock Text="{Binding RegistryStatus}" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Вкладка 2: Разблокировка ограничений -->
        <TabItem Header="🔓 Разблокировка" Background="#2D2D30" Foreground="#CCCCCC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Разблокировка ограничений Windows" FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,5"/>
                        <TextBlock Text="Восстановление ограничений вируса или системы" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,15"/>

                        <Button Content="🔓 Восстановить ВСЁ" Command="{Binding RestoreAllCommand}"
                                Padding="20,10" Margin="0,0,0,15" Background="#107C10" Foreground="White" FontSize="14" FontWeight="Bold"/>

                        <WrapPanel>
                            <Button Content="📋 Диспетчер задач" Command="{Binding EnableTaskManagerCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="🔧 Реестр" Command="{Binding EnableRegistryEditorCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="💻 CMD" Command="{Binding EnableCMDCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="⚙️ Панель" Command="{Binding EnableControlPanelCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="🔒 UAC" Command="{Binding EnableUACCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="👁️ Скрытые" Command="{Binding ShowHiddenFilesCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="📄 Расширения" Command="{Binding ShowExtensionsCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="🛡️ Defender" Command="{Binding ResetDefenderCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="🔥 Брандмауэр" Command="{Binding ResetFirewallCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="🩺 Восстановление" Command="{Binding RepairWindowsCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                            <Button Content="📝 Hosts" Command="{Binding ResetHostsCommand}" Padding="15,8" Margin="5"
                                    Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#3F3F46"/>

                <!-- Результаты -->
                <Border Grid.Column="2" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10">
                            <TextBlock Text="📋 Результаты" FontSize="14" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding UnlockStatus}" Foreground="#AAAAAA" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </TabItem>

        <!-- Вкладка 3: Горячие клавиши -->
        <TabItem Header="⌨️ Горячие клавиши" Background="#2D2D30" Foreground="#CCCCCC">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <TextBlock Text="Нажмите кнопку для эмуляции горячей клавиши" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,15"/>

                    <!-- Системные -->
                    <TextBlock Text="🖥️ Системные" FontSize="14" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,15">
                        <Button Content="Win+L 🔒" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin l" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Блокировка экрана"/>
                        <Button Content="Win+D 📌" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin d" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Показать рабочий стол"/>
                        <Button Content="Win+E 📂" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin e" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Проводник"/>
                        <Button Content="Win+R 🏃" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin r" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Выполнить"/>
                        <Button Content="Win+I ⚙️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin i" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Параметры"/>
                        <Button Content="Win+X 📋" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin x" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Быстрое меню"/>
                        <Button Content="Win+Tab 🖥️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin tab" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Task View"/>
                        <Button Content="Win+V 📋" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin v" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Буфер обмена"/>
                        <Button Content="Win+Pause ℹ️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lwin pause" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Свойства системы"/>
                    </WrapPanel>

                    <!-- Процессы -->
                    <TextBlock Text="⚙️ Процессы" FontSize="14" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,15">
                        <Button Content="Ctrl+Shift+Esc ⚙️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lctrl lshift esc" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Диспетчер задач"/>
                        <Button Content="Alt+F4 ✖️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lalt f4" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Закрыть окно"/>
                        <Button Content="Alt+Tab ↔️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lalt tab" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Переключение окон"/>
                        <Button Content="Alt+Enter 📄" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lalt enter" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Свойства выделенного"/>
                    </WrapPanel>

                    <!-- Проводник -->
                    <TextBlock Text="📂 Проводник" FontSize="14" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <Button Content="F2 ✏️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="f2" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Переименовать"/>
                        <Button Content="F5 🔄" Command="{Binding SimulateHotkeyCommand}" CommandParameter="f5" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Обновить"/>
                        <Button Content="Delete 🗑️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="delete" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Удалить"/>
                        <Button Content="Ctrl+C 📋" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lctrl c" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Копировать"/>
                        <Button Content="Ctrl+V 📄" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lctrl v" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Вставить"/>
                        <Button Content="Ctrl+X ✂️" Command="{Binding SimulateHotkeyCommand}" CommandParameter="lctrl x" Padding="12,6" Margin="3"
                                Background="#2D2D30" Foreground="#CCCCCC" BorderBrush="#3E3E42" BorderThickness="1" ToolTip="Вырезать"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</UserControl>
