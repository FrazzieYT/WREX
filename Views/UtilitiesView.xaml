<UserControl x:Class="SystemManager.Views.UtilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SystemManager.ViewModels">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="CardBorder" Color="#3E3E42"/>
        <SolidColorBrush x:Key="CardHoverBackground" Color="#3E3E42"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
        <StackPanel Margin="20">
            <TextBlock Text="Системные утилиты" FontSize="24" FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
            <TextBlock Text="Быстрый запуск встроенных инструментов Windows" 
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,20"/>

            <ItemsControl ItemsSource="{Binding Utilities}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:UtilityItem}">
                        <Button Command="{Binding DataContext.LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding IsAvailable}"
                                Width="180" Height="80" Margin="5"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" 
                                            Background="{StaticResource CardBackground}" 
                                            BorderBrush="{StaticResource CardBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Description}" 
                                                       FontSize="11" 
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" 
                                                    Value="{StaticResource CardHoverBackground}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Точки восстановления -->
            <TextBlock Text="Точки восстановления системы" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,30,0,10"/>
            <TextBlock Text="Управление точками восстановления Windows" 
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="🔄 Обновить" 
                        Command="{Binding RefreshRestorePointsCommand}"
                        Padding="15,8" Margin="0,0,10,0"
                        Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="➕ Создать точку" 
                        Command="{Binding CreateRestorePointCommand}"
                        Padding="15,8"
                        Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}"
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
            </StackPanel>

            <ListView ItemsSource="{Binding RestorePoints}" 
                      Background="{StaticResource CardBackground}"
                      Foreground="{StaticResource TextPrimary}"
                      BorderBrush="{StaticResource CardBorder}"
                      BorderThickness="1"
                      MaxHeight="300">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="#" Width="50" DisplayMemberBinding="{Binding SequenceNumber}"/>
                        <GridViewColumn Header="Описание" Width="250" DisplayMemberBinding="{Binding Description}"/>
                        <GridViewColumn Header="Дата" Width="150" DisplayMemberBinding="{Binding FormattedTime}"/>
                        <GridViewColumn Header="Тип" Width="180" DisplayMemberBinding="{Binding TypeDisplay}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Трекинг установки -->
            <TextBlock Text="Трекинг установки ПО" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,30,0,10"/>
            <TextBlock Text="Мониторинг изменений файлов и реестра во время установки программ" 
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" 
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📡" FontSize="24" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Мониторинг файловой системы и реестра" FontSize="14"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Запустите перед установкой программы для отслеживания всех изменений" FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal">
                <Button Content="▶️ Начать трекинг" 
                        Command="{Binding StartTrackingCommand}"
                        Padding="15,8" Margin="0,0,10,0"
                        Background="#107C10"
                        Foreground="White"/>
                <Button Content="⏹ Остановить" 
                        Command="{Binding StopTrackingCommand}"
                        Padding="15,8"
                        Background="#C50F1F"
                        Foreground="White"/>
            </StackPanel>

            <!-- Восстановление Windows -->
            <TextBlock Text="Восстановление Windows" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,30,0,10"/>
            <TextBlock Text="Инструменты для восстановления системы после вирусов и сбоев" 
                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>

            <WrapPanel>
                <Button Content="🔒 Включить UAC" Command="{Binding EnableUACCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="🔓 Отключить UAC" Command="{Binding DisableUACCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="📋 Диспетчер задач" Command="{Binding EnableTaskManagerCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="🔧 Реестр" Command="{Binding EnableRegistryEditorCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="💻 CMD" Command="{Binding EnableCMDCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="⚙️ Панель управления" Command="{Binding EnableControlPanelCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="👁️ Скрытые файлы" Command="{Binding ShowHiddenFilesCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="📄 Расширения" Command="{Binding ShowExtensionsCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="🛡️ Defender" Command="{Binding ResetDefenderCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="🔥 Брандмауэр" Command="{Binding ResetFirewallCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="🩺 Восстановление" Command="{Binding RepairWindowsCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
                <Button Content="📝 Hosts" Command="{Binding ResetHostsCommand}"
                        Padding="15,8" Margin="5" Background="{StaticResource CardBackground}"
                        Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1"/>
            </WrapPanel>

            <!-- Экспорт системной информации -->
            <TextBlock Text="Экспорт информации" FontSize="18" FontWeight="SemiBold" 
                       Foreground="{StaticResource TextPrimary}" Margin="0,30,0,10"/>
            <Button Content="📄 Экспорт системной информации" Command="{Binding ExportSystemInfoCommand}"
                    Padding="15,8" Background="{StaticResource AccentColor}"
                    Foreground="White"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>