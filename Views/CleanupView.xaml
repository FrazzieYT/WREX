<UserControl x:Class="SystemManager.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentColor" Color="#0078D4"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#107C10"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFB900"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E81123"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="30,30,30,20">
            <TextBlock Text="Очистка системы" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
            <TextBlock Text="Удаление временных файлов и кэша" FontSize="14"
                       Foreground="{StaticResource TextSecondary}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,0,30,30">
                <!-- Статистика -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,20"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Удалено файлов" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding TotalDeletedFiles}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Удалено папок" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding TotalDeletedDirectories}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Освобождено" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                            <TextBlock Text="{Binding FormattedFreedBytes}" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessColor}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Полная очистка -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20" Margin="0,0,0,15"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="🧹 Полная очистка" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Очистка всех временных папок и кэша" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Запустить" Command="{Binding FullCleanupCommand}"
                                Padding="20,8" Background="{StaticResource AccentColor}" Foreground="White"/>
                    </Grid>
                </Border>

                <TextBlock Text="Отдельные операции" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,10,0,10"/>

                <!-- Temp -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="📄 Временные файлы (Temp)" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="%TEMP% - временные файлы пользователя" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Очистить" Command="{Binding CleanTempCommand}"
                                Padding="15,6" Background="{StaticResource WarningColor}" Foreground="White"/>
                    </Grid>
                </Border>

                <!-- Prefetch -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="⚡ Prefetch" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Кэш запуска приложений" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Очистить" Command="{Binding CleanPrefetchCommand}"
                                Padding="15,6" Background="{StaticResource WarningColor}" Foreground="White"/>
                    </Grid>
                </Border>

                <!-- Recent -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="📋 Недавние документы" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Ярлыки недавно открытых файлов" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Очистить" Command="{Binding CleanRecentCommand}"
                                Padding="15,6" Background="{StaticResource WarningColor}" Foreground="White"/>
                    </Grid>
                </Border>

                <!-- Windows Temp -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="🪟 Windows Temp" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Системные временные файлы" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Очистить" Command="{Binding CleanWindowsTempCommand}"
                                Padding="15,6" Background="{StaticResource WarningColor}" Foreground="White"/>
                    </Grid>
                </Border>

                <!-- Результат -->
                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20" Margin="0,20,0,0"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Результат" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding LastResult}" FontSize="13"
                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
